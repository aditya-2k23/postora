rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() { return request.auth != null; }
    function existing() { return resource.data; }
    function incoming() { return request.resource.data; }

    function isValidId(id) { 
      return id is string 
          && id.size() <= 128 
          && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function isProject(data, isCreate) {
      let requiredKeys = ['userId', 'prompt', 'platform', 'aspectRatio', 'createdAt', 'updatedAt'];
      let permittedKeys = ['id', 'userId', 'prompt', 'platform', 'aspectRatio', 'themeSettings', 'cards', 'createdAt', 'updatedAt'];
      
      return data.keys().hasAll(requiredKeys)
        && (isCreate ? data.keys().hasOnly(permittedKeys) : true)
        && data.userId == request.auth.uid
        && data.prompt is string && data.prompt.size() <= 5000
        && data.platform is string && data.platform.size() <= 100
        && data.aspectRatio is string && data.aspectRatio.size() <= 20
        && data.createdAt is timestamp
        && data.updatedAt is timestamp
        && (!('id' in data) || (data.id is string && data.id.size() <= 128))
        && (!('cards' in data) || (data.cards is list && data.cards.size() <= 50))
        && (!('themeSettings' in data) || (
          data.themeSettings is map 
          && (!('primaryColor' in data.themeSettings) || (data.themeSettings.primaryColor is string && data.themeSettings.primaryColor.size() <= 20))
          && (!('fontSize' in data.themeSettings) || (data.themeSettings.fontSize is number && data.themeSettings.fontSize > 0 && data.themeSettings.fontSize <= 100))
          && (!('style' in data.themeSettings) || (data.themeSettings.style is string && data.themeSettings.style.size() <= 50))
        ));
    }

    match /users/{userId}/projects/{projectId} {
      // Must check resource.data to prevent blanket list
      allow get: if isSignedIn() && existing().userId == request.auth.uid;
      allow list: if isSignedIn() && existing().userId == request.auth.uid;
      
      allow create: if isSignedIn() 
        && isValidId(projectId)
        && isProject(incoming(), true)
        && incoming().createdAt == request.time
        && incoming().updatedAt == request.time
        && incoming().userId == userId;

      allow update: if isSignedIn()
        && isValidId(projectId)
        && existing().userId == request.auth.uid
        && isProject(incoming(), false)
        && incoming().createdAt == existing().createdAt
        && incoming().userId == existing().userId
        && incoming().updatedAt == request.time
        && incoming().diff(existing()).affectedKeys().hasOnly(['prompt', 'platform', 'aspectRatio', 'themeSettings', 'cards', 'updatedAt']);

      allow delete: if isSignedIn() && existing().userId == request.auth.uid;
    }
  }
}
